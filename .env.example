# Cloudach Environment Variables
# Copy to .env and fill in values before running docker-compose.
#   cp .env.example .env

# ─── Auth (shared by dashboard and API gateway) ──────────────────────────────
# Must match across both services. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# ─── Database ────────────────────────────────────────────────────────────────
# Used by the Next.js dashboard (server-side API routes) and indirectly by the
# API gateway via DB_URL below.
DATABASE_URL=postgresql://cloudach:cloudach@postgres:5432/cloudach

# Postgres container credentials (must match DATABASE_URL)
POSTGRES_USER=cloudach
POSTGRES_PASSWORD=cloudach
POSTGRES_DB=cloudach

# ─── API Gateway ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# Points at the vLLM mock in docker-compose; swap for real vLLM in production
VLLM_BASE_URL=http://vllm-mock:8000

# ─── Dashboard (Next.js) ─────────────────────────────────────────────────────
# Public URL of the API gateway — browser-accessible (not the docker network name)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── AWS / Cloud inference (optional — falls back to vllm-mock when unset) ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── GCP / GKE (CI/CD only) ──────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
GKE_CLUSTER=cloudach-prod
GAR_LOCATION=us-central1
GAR_REPOSITORY=cloudach

# ─── Vercel (deploy target for dashboard, optional) ──────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ─── Hugging Face (model downloads, optional) ────────────────────────────────
HUGGING_FACE_HUB_TOKEN=
